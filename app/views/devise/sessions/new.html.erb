<div class="row justify-content-center mt-5">
  <div class="col-md-4">
    <div class="card shadow border-0">
      <div class="card-body p-4">
        <div class="text-center mb-4">
          <h2 class="fw-bold">Welcome Back</h2>
          <p class="text-muted small">Log in to sync your daily updates</p>
        </div>

        <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
          
          <div class="mb-3">
            <%= f.label :email, class: "form-label fw-bold small" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", 
                class: "form-control", placeholder: "name@example.com" %>
          </div>

          <div class="mb-3">
            <div class="d-flex justify-content-between">
              <%= f.label :password, class: "form-label fw-bold small" %>
            </div>
            <%= f.password_field :password, autocomplete: "current-password", 
                class: "form-control", placeholder: "Enter your password" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="form-check mb-4">
              <%= f.check_box :remember_me, class: "form-check-input" %>
              <%= f.label :remember_me, class: "form-check-label small text-muted" %>
            </div>
          <% end %>

          <div class="d-grid mb-3">
            <%= f.submit "Log in", class: "btn btn-primary fw-bold py-2" %>
          </div>
        <% end %>

        <div class="text-center mt-4">
          <%= link_to "Create an account", new_registration_path(resource_name), class: "btn btn-outline-primary w-100 fw-bold" %>
        </div>

        <div class="text-center mt-3">
          <%= link_to "Forgot Password", new_password_path(resource_name), class: "text-primary" %>
        </div>
      </div>
    </div>
    
    
  </div>
</div>